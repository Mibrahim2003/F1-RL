# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
develop-eggs/
wheels/
pip-wheel-metadata/

# Virtual environments — anchored to the repo root so they only catch a top-level venv dir.
# Unanchored "env/" matched the source package src/f1rl/env/ (case-insensitively on Windows),
# which silently dropped the whole env package from every commit. Keep these anchored (leading /).
/.venv/
/venv/
/env/
/ENV/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# ---- Project data & artifacts ----
# FastF1 telemetry cache (build-time only, never committed)
data/raw_telemetry/
# Training outputs
checkpoints/
runs/
wandb/
outputs/
*.mp4
*.pt
*.ckpt

# Processed tracks are committed as the cache (rollback plan §f); uncomment to drop them.
# data/tracks/
# Surface-editor rollback backups are local-only.
data/tracks/*.npz.bak
# Recorded trajectories (Phase 1 app)
recordings/

# ---- Web frontend (web/) ----
web/node_modules/
web/dist/
web/.vite/

# ---- Editor / OS ----
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---- Claude Code ----
# Local, machine-specific settings (permissions etc.). Shared settings.json is kept.
.claude/settings.local.json
